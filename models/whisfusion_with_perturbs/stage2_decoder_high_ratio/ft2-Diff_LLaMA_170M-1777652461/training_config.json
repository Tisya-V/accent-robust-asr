  "perturb_prob": 0.3,
  "include_perturb_in_loss": true,
  "perturber_k": 10,
  "perturber_cache_dir": "src/utils/cache",
  "use_layer_wise_lr_decay": true,
  "layer_wise_lr_decay_rate": 0.9,
  "lr_scaling": "linear",
  "warmup_ratio": 0.1,
  "use_ema": true,
  "ema_decay": 0.995,
  "val_steps": -1,
  "patience": 5,
  "compute_wer_cer": true,
  "early_stop_metric": "loss",
  "save_every_n_epochs": 5,
  "num_devices": 3,
  "num_workers": 4,
  "precision": "32-true",
  "gradient_accumulation_steps": 2,
  "min_mask_ratio": 0.7,
  "max_mask_ratio": 1.0,
  "resume": false
